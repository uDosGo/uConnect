{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "uDos adaptor baseline schema",
  "type": "object",
  "required": ["name", "version", "runtime"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "runtime": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["node", "python", "static", "emulated"] },
        "port": { "type": "integer", "minimum": 1 },
        "build": { "type": "string" },
        "start": { "type": "string" }
      },
      "additionalProperties": true
    },
    "integration": {
      "type": "object",
      "properties": {
        "variables": { "type": "array" },
        "api": { "type": "array" },
        "events": { "type": "array" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
