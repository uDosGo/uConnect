#!/usr/bin/env python3
"""
uCode - Unified CLI for uDos Ecosystem

Consolidates all uCode1 subsystems (snack, binder, relic, usxd, grid,
thinui, vault) into a single, coherent command-line interface.

Usage:
  ucode <command> [<subcommand>] [options]

Commands:
  ok          OK Agent — local AI assistant
  narrator    Narrator — story generation from events
  lexicon     Lexicon — term mapping across dev/story/student lanes
  character   Character system — 128-slot ANSI set, emoji, aliases
  cell        Cell storage — UDX-addressed atomic units + Cubes
  snack       Snack management (create, validate, run, list)
  binder      Binder management (create, validate, extract, tree)
  relic       Relic management (create, validate, pack, unpack)
  usxd        USXD document management (parse, render, map, export)
  grid        ASCII grid operations (parse, render, interactive, edit)
  thinui      ThinUI bridge (parse, render, api, themes)
  mdx         MDX document processing with Snack shortcodes
  vault       Vault operations (read, write, list, search)
  plugin      Plugin management (list, enable, disable)
  help        Show help for a command

Options:
  --help, -h   Show this help message
  --version    Show version
  --debug      Enable debug output

Examples:
  ucode snack list
  ucode usxd parse --text "┌───┐\\n│ A │\\n└───┘"
  ucode grid interactive my_grid.txt
  ucode thinui themes
  ucode vault list /
"""

import argparse
import os
import sys

# Add parent dir so we can import core_py
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

VERSION = "0.1.0"


def main():
    if len(sys.argv) < 2:
        show_help()
        return

    command = sys.argv[1]

    # Strip argv[1] so sub-command handlers get clean args
    handlers = {
        "ok":       lambda: dispatch_cli("ok_agent.cli"),
        "narrator": lambda: dispatch_cli("narrator.cli"),
        "lexicon":  lambda: dispatch_with_prefix("narrator.cli", "lexicon"),
        "character": lambda: dispatch_with_prefix("narrator.cli", "character"),
        "snack":    lambda: dispatch("snack_cli"),
        "binder":   lambda: dispatch("binder_cli"),
        "relic":    lambda: dispatch("relic_cli"),
        "usxd":     lambda: dispatch("usxd_cli"),
        "grid":     lambda: dispatch("grid_cli"),
        "thinui":   lambda: dispatch_cli("thinui_cli"),
        "mdx":      lambda: dispatch("mdx_cli"),
        "cell":     lambda: dispatch("cell_cli"),
        "vault":    lambda: dispatch_cli("vault_cli"),
        "plugin":   lambda: dispatch_cli("plugin_cli"),
        "help":     lambda: show_help(),
        "--help":   lambda: show_help(),
        "-h":       lambda: show_help(),
        "--version": lambda: print(f"uCode v{VERSION}"),
    }

    handler = handlers.get(command)
    if handler:
        handler()
    else:
        print(f"uCode: unknown command '{command}'")
        print("Run 'ucode --help' for usage.")
        sys.exit(1)


def dispatch(module_name: str):
    """Import and run a standalone CLI module by name."""
    try:
        mod = __import__(module_name, fromlist=["main"])
        # Remove 'ucode' and the subcommand name from argv
        sys.argv = [module_name + ".py"] + sys.argv[2:]
        mod.main()
    except ImportError as e:
        print(f"Error loading {module_name}: {e}")
        sys.exit(1)


def dispatch_with_prefix(module_path: str, prefix: str):
    """Import a CLI module and run its main with a prefix in argv."""
    parts = module_path.split(".")
    mod_name = parts[0]
    try:
        mod = __import__(mod_name, fromlist=parts[1:])
        for attr in parts[1:]:
            mod = getattr(mod, attr)
        sys.argv = [module_path, prefix] + sys.argv[2:]
        mod.main()
    except (ImportError, AttributeError) as e:
        print(f"Error loading {module_path}: {e}")
        sys.exit(1)


def dispatch_cli(module_path: str):
    """Import and run a CLI module from a dotted path."""
    parts = module_path.split(".")
    mod_name = parts[0]
    try:
        mod = __import__(mod_name, fromlist=parts[1:])
        for attr in parts[1:]:
            mod = getattr(mod, attr)
        sys.argv = [module_path] + sys.argv[2:]
        mod.main()
    except (ImportError, AttributeError) as e:
        print(f"Error loading {module_path}: {e}")
        sys.exit(1)


def show_help():
    print(__doc__.strip())
    print()
    print("Available sub-systems:")
    print()

    # Show snack commands
    try:
        mod = __import__("snack_cli", fromlist=["main"])
        if hasattr(mod, "build_arg_parser"):
            p = mod.build_arg_parser()
            print("  [snack]")
            for a in p._subparsers._group_actions[0].choices:
                print(f"    {a}")
    except Exception:
        pass


if __name__ == "__main__":
    main()
