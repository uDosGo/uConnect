#!/usr/bin/env bash
# =============================================================================
# uCode1 Pre-Commit Hook
#
# Runs before every commit to ensure code quality, tests pass, and
# no obvious issues are introduced.
#
# Installation:
#   git config core.hooksPath .githooks
#   # or symlink: ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit
#
# Checks performed:
#   1. Python syntax check on all .py files
#   2. Import sanity (can core modules be loaded?)
#   3. Run full test suite (pytest)
#   4. Check for debug/print statements left in production code
#   5. Validate snack.yaml files if changed
#   6. Check for large binary files being committed
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
cd "$REPO_ROOT"

# If we're in the uDosGo repo and uCode1 is a subdirectory, cd into it
if [ -d "uCode1" ]; then
    cd uCode1
fi

# ── Configuration ──────────────────────────────────────────────────────────
MAX_BINARY_SIZE_MB=1
EXCLUDED_DIRS="__pycache__|.git|.venv|node_modules|dist|build"
FAILED=0

# ── Helper Functions ───────────────────────────────────────────────────────

info()    { echo -e "${CYAN}[pre-commit]${NC} $1"; }
pass()    { echo -e "${GREEN}[pre-commit]${NC} $1"; }
warn()    { echo -e "${YELLOW}[pre-commit]${NC} $1"; }
fail()    { echo -e "${RED}[pre-commit]${NC} $1"; FAILED=1; }

section() {
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}  $1${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

run_check() {
    local name="$1"
    shift
    info "Running: $name..."
    if "$@" 2>&1; then
        pass "$name: OK"
    else
        fail "$name: FAILED"
    fi
}

# ── 1. Python Syntax Check ─────────────────────────────────────────────────

section "1/6 — Python Syntax Check"

STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$STAGED_PY_FILES" ]; then
    while IFS= read -r f; do
        if python -c "compile(open('$f','rb').read(), '$f', 'exec')" 2>/dev/null; then
            pass "  ✓ $f (syntax OK)"
        else
            fail "  ✗ $f (syntax error)"
            python -c "compile(open('$f','rb').read(), '$f', 'exec')" 2>&1 || true
        fi
    done <<< "$STAGED_PY_FILES"
else
    info "No Python files staged, skipping syntax check"
fi

# ── 2. Import Sanity ───────────────────────────────────────────────────────

section "2/6 — Import Sanity Check"

# Check that the core modules can be imported
IMPORT_CHECKS=(
    "core_py.bbc.interpreter"
    "core_py.bbc.lens"
    "core_py.bbc.skin"
    "core_py.bbc.mcp_bridge"
    "core_py.bbc.spool_bridge"
    "core_py.bbc.lens_skin_mcp"
    "core_py.snack_container"
    "core_py.snack"
    "core_py.grid"
    "core_py.text"
    "core_py.themes"
    "core_py.thinui"
    "core_py.usxd"
    "core_py.export"
    "core_py.liquid_engine"
    "core_py.mdx"
    "core_py.plugin"
    "core_py.relic"
    "core_py.binder"
    "core_py.cell"
    "core_py.feed"
    "narrator"
    "ok_agent"
)

for mod in "${IMPORT_CHECKS[@]}"; do
    if python -c "import $mod" 2>/dev/null; then
        pass "  ✓ $mod"
    else
        warn "  ⚠ $mod (not importable — may be optional)"
    fi
done

# ── 3. Run Full Test Suite ─────────────────────────────────────────────────

section "3/6 — Running Test Suite"

if command -v pytest &>/dev/null; then
    if python -m pytest tests/ -v --tb=short -q 2>&1; then
        pass "All tests passed"
    else
        fail "Some tests failed — review output above"
    fi
else
    warn "pytest not found, skipping test suite"
fi

# ── 4. Check for Debug/Print Statements ────────────────────────────────────

section "4/6 — Debug Statement Check"

if [ -n "$STAGED_PY_FILES" ]; then
    while IFS= read -r f; do
        # Skip test files — they're allowed to have print/pdb
        if [[ "$f" == tests/* ]] || [[ "$f" == examples/* ]]; then
            continue
        fi
        # Check for pdb/set_trace
        if grep -n "pdb.set_trace()\|breakpoint()\|import pdb" "$f" 2>/dev/null; then
            fail "  ✗ $f contains debugger breakpoint"
        fi
        # Check for print() in production code (heuristic: warn only)
        if grep -n "^[^#]*print(" "$f" 2>/dev/null | grep -v 'print("\\[pre-commit\\]' | head -5; then
            warn "  ⚠ $f contains print() statements (may be intentional)"
        fi
    done <<< "$STAGED_PY_FILES"
    pass "Debug statement check complete"
else
    info "No Python files staged, skipping debug check"
fi

# ── 5. Validate Snack YAML Files ───────────────────────────────────────────

section "5/6 — Snack YAML Validation"

STAGED_YAML_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(yaml|yml)$' || true)

if [ -n "$STAGED_YAML_FILES" ]; then
    while IFS= read -r f; do
        # Only validate files named snack.yaml or snackpack.yaml
        basename=$(basename "$f")
        if [[ "$basename" == "snack.yaml" ]] || [[ "$basename" == "snackpack.yaml" ]]; then
            if python -c "
import sys, yaml
try:
    with open('$f') as fh:
        data = yaml.safe_load(fh)
    if data is None:
        print('Empty YAML file')
        sys.exit(1)
    if 'name' not in data:
        print('Missing required field: name')
        sys.exit(1)
    if 'version' not in data:
        print('Missing required field: version')
        sys.exit(1)
    print('Valid snack manifest')
except yaml.YAMLError as e:
    print(f'YAML parse error: {e}')
    sys.exit(1)
" 2>&1; then
                pass "  ✓ $f (valid)"
            else
                fail "  ✗ $f (invalid)"
            fi
        fi
    done <<< "$STAGED_YAML_FILES"
else
    info "No YAML files staged, skipping validation"
fi

# ── 6. Check for Large Binary Files ────────────────────────────────────────

section "6/6 — Large File Check"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)

if [ -n "$STAGED_FILES" ]; then
    while IFS= read -r f; do
        # Skip if file doesn't exist (deleted)
        [ -f "$f" ] || continue
        # Skip excluded directories
        echo "$f" | grep -qE "$EXCLUDED_DIRS" && continue

        size=$(stat -f%z "$f" 2>/dev/null || stat -c%s "$f" 2>/dev/null || echo 0)
        size_mb=$(echo "scale=2; $size / 1048576" | bc 2>/dev/null || echo 0)

        if [ "$(echo "$size_mb > $MAX_BINARY_SIZE_MB" | bc 2>/dev/null || echo 0)" = "1" ]; then
            # Check if it's a binary file
            if file "$f" | grep -qE "binary|image|archive|executable"; then
                fail "  ✗ $f is ${size_mb}MB binary (max: ${MAX_BINARY_SIZE_MB}MB)"
            fi
        fi
    done <<< "$STAGED_FILES"
    pass "Large file check complete"
else
    info "No files staged, skipping large file check"
fi

# ── Summary ────────────────────────────────────────────────────────────────

echo ""
section "Summary"

if [ "$FAILED" -eq 0 ]; then
    echo -e "${GREEN}  ✅ All checks passed — ready to commit!${NC}"
    echo ""
    exit 0
else
    echo -e "${RED}  ❌ Some checks failed — review issues above${NC}"
    echo ""
    echo -e "${YELLOW}  To bypass checks (not recommended): git commit --no-verify${NC}"
    echo ""
    exit 1
fi
