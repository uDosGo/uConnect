#!/bin/bash
# =============================================================================
# uDosGo Pre-Commit Hook
# =============================================================================
# Runs local checks before each commit to catch issues early.
# Mirrors the CI pipeline checks but runs only what's feasible locally.
#
# Installation:
#   make hooks-install        # Symlink .githooks/* into .git/hooks/
#   # or manually:
#   git config core.hooksPath .githooks
#
# Skip checks (emergency override):
#   git commit --no-verify
#   SKIP=ruff,rust git commit
# =============================================================================

set -euo pipefail

# ── Config ──────────────────────────────────────────────────────────────────
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$HOOK_DIR/.." && pwd)"
TIMESTAMP="$(date '+%H:%M:%S')"

# Source shared helpers
# shellcheck source=lib/shared.sh
source "$HOOK_DIR/lib/shared.sh"

# ── Determine what changed ──────────────────────────────────────────────────
CHANGED_PYTHON=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.py$' || true)
CHANGED_RUST=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.rs$' || true)
CHANGED_JS=$(git diff --cached --name-only --diff-filter=ACMR | grep -cE '\.(js|ts|vue)$' || true)
CHANGED_YAML=$(git diff --cached --name-only --diff-filter=ACMR | grep -cE '\.(yaml|yml)$' || true)
CHANGED_PROTO=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.proto$' || true)
CHANGED_MD=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.md$' || true)
CHANGED_SHELL=$(git diff --cached --name-only --diff-filter=ACMR | grep -cE '\.(sh|bash)$' || true)
CHANGED_DOCKER=$(git diff --cached --name-only --diff-filter=ACMR | grep -cE '(Dockerfile|docker-compose|\.dockerfile)' || true)
CHANGED_TOML=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.toml$' || true)
CHANGED_JSON=$(git diff --cached --name-only --diff-filter=ACMR | grep -c '\.json$' || true)
CHANGED_ANY=$(( CHANGED_PYTHON + CHANGED_RUST + CHANGED_JS + CHANGED_YAML + CHANGED_PROTO + CHANGED_MD + CHANGED_SHELL + CHANGED_DOCKER + CHANGED_TOML + CHANGED_JSON ))

# ── Header ──────────────────────────────────────────────────────────────────
echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║   🧪 uDosGo Pre-Commit Checks                               ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# ── Run checks ─────────────────────────────────────────────────────────────
FAILED=0
CHECKS_RUN=0

# 1. Python checks (uCode1)
if [ "$CHANGED_PYTHON" -gt 0 ] || [ "$CHANGED_ANY" -eq 0 ]; then
    if should_run "ruff"; then
        run_check "ruff (Python linter)" "$HOOK_DIR/checks/ruff.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
    if should_run "mypy"; then
        run_check "mypy (Python type check)" "$HOOK_DIR/checks/mypy.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
    if should_run "pytest-quick"; then
        run_check "pytest (quick)" "$HOOK_DIR/checks/pytest-quick.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 2. Rust checks (uCode2)
if [ "$CHANGED_RUST" -gt 0 ] || [ "$CHANGED_ANY" -eq 0 ]; then
    if should_run "rustfmt"; then
        run_check "rustfmt (Rust formatting)" "$HOOK_DIR/checks/rustfmt.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
    if should_run "clippy"; then
        run_check "clippy (Rust linter)" "$HOOK_DIR/checks/clippy.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
    if should_run "cargo-check"; then
        run_check "cargo check (Rust compilation)" "$HOOK_DIR/checks/cargo-check.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 3. JavaScript/TypeScript checks
if [ "$CHANGED_JS" -gt 0 ] || [ "$CHANGED_ANY" -eq 0 ]; then
    if should_run "eslint"; then
        run_check "ESLint (JS/TS)" "$HOOK_DIR/checks/eslint.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 4. Protobuf checks
if [ "$CHANGED_PROTO" -gt 0 ]; then
    if should_run "protolint"; then
        run_check "Protobuf lint" "$HOOK_DIR/checks/protolint.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 5. YAML checks
if [ "$CHANGED_YAML" -gt 0 ]; then
    if should_run "yaml-lint"; then
        run_check "YAML lint" "$HOOK_DIR/checks/yaml-lint.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 6. Shell script checks
if [ "$CHANGED_SHELL" -gt 0 ]; then
    if should_run "shellcheck"; then
        run_check "ShellCheck" "$HOOK_DIR/checks/shellcheck.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 7. Markdown checks
if [ "$CHANGED_MD" -gt 0 ]; then
    if should_run "markdown-lint"; then
        run_check "Markdown lint" "$HOOK_DIR/checks/markdown-lint.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 8. Docker checks
if [ "$CHANGED_DOCKER" -gt 0 ]; then
    if should_run "docker-lint"; then
        run_check "Dockerfile lint" "$HOOK_DIR/checks/docker-lint.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 9. JSON checks
if [ "$CHANGED_JSON" -gt 0 ]; then
    if should_run "json-lint"; then
        run_check "JSON validation" "$HOOK_DIR/checks/json-lint.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 10. TOML checks
if [ "$CHANGED_TOML" -gt 0 ]; then
    if should_run "toml-lint"; then
        run_check "TOML validation" "$HOOK_DIR/checks/toml-lint.sh" || ((FAILED++))
        ((CHECKS_RUN++))
    fi
fi

# 11. Always-run checks (merge conflict markers, large files, etc.)
if should_run "conflict-markers"; then
    run_check "Merge conflict markers" "$HOOK_DIR/checks/conflict-markers.sh" || ((FAILED++))
    ((CHECKS_RUN++))
fi

if should_run "large-files"; then
    run_check "Large files" "$HOOK_DIR/checks/large-files.sh" || ((FAILED++))
    ((CHECKS_RUN++))
fi

if should_run "private-keys"; then
    run_check "Private keys/secrets" "$HOOK_DIR/checks/private-keys.sh" || ((FAILED++))
    ((CHECKS_RUN++))
fi

# ── Summary ─────────────────────────────────────────────────────────────────
echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
if [ "$FAILED" -eq 0 ]; then
    echo "║   ✅ All $CHECKS_RUN checks passed!                           ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 0
else
    echo "║   ❌ $FAILED/$CHECKS_RUN checks FAILED                              ║"
    echo "║                                                              ║"
    echo "║   To skip checks (emergency only):                           ║"
    echo "║     git commit --no-verify                                   ║"
    echo "║     SKIP=ruff,rust git commit                                ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi
