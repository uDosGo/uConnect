#!/bin/bash
# udo - Unified CLI for the uDos ecosystem
# Usage: udo <command> [args...]
# This is a thin orchestrator that wraps existing tools.

set -euo pipefail

UDO_HOME="${UDO_HOME:-$HOME/Code/uDosGo/udo}"
UDO_UI="${UDO_UI:-$HOME/Code/uDosGo/ui}"
UDO_FONTS="${UDO_FONTS:-$UDO_HOME/fonts}"
UDO_SKILLS="${UDO_SKILLS:-$UDO_HOME/skills}"
UDO_VAULT="${UDO_VAULT:-$HOME/Vault}"
UDO_EXTENSIONS="${UDO_EXTENSIONS:-$HOME/Code/uDosGo/udoui/extensions}"
UDO_EXT_REGISTRY="${UDO_EXT_REGISTRY:-$HOME/.local/share/udoui/extensions}"
UDO_VERSION="1.1.0"


# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Helper functions
info()  { echo -e "${BLUE}ℹ${NC} $1"; }
ok()    { echo -e "${GREEN}✓${NC} $1"; }
warn()  { echo -e "${YELLOW}⚠${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1"; }

# Show usage
usage() {
    cat <<EOF
udo v${UDO_VERSION} — Unified uDos CLI

Usage: udo <command> [args...]

Core Automation:
  run <skill> [--params]        Execute a skill/snack/spice (containerised action)
  task add <desc>               Create a new task
  task list [--status] [--pri]  List tasks with filters
  task show <id>                Show task details
  task do <id>                  Mark task as complete
  task undo <id>                Reopen completed task
  task delete <id>              Delete a task
  task tag <id> <tag>           Add label to task
  task assign <id> <agent|user> Assign task

Surface Control:
  surface list                  List available surfaces
  surface open <name>           Open a surface
  surface close <name>          Close a surface
  surface focus <name>          Switch to surface

Vault (Storage):
  vault get <path>              Read from vault
  vault set <path> <value>      Write to vault
  vault list <path>             List vault contents
  vault watch <path>            Watch for changes
  vault sync                    Sync vault with remotes
  vault backup [dir]            Create vault backup

Agent Orchestration:
  agent list                    List available agents
  agent call <name> --prompt    Call an agent with a prompt
  agent status <name>           Check agent status
  agent stop <name>             Stop an agent

Oracle Trinity:
  oracle ask <query>            Ask the oracles a question
  oracle list                   List available oracles
  oracle status                 Show oracle status

MCP Bridge:
  mcp list                      List MCP tools
  mcp call <tool> [--params]    Call an MCP tool
  mcp server start <name>       Start an MCP server
  mcp server stop <name>        Stop an MCP server

System:
  start                         Start all uDos services
  stop                          Stop all uDos services
  restart                       Restart all uDos services
  status                        Show system status
  ui                            Launch udoui web interface
  setup                         Initial setup/install
  init <project>                Project scaffolding
  dev [start|stop|status]       Dev mode operations

Configuration:
  config show                   Show current configuration
  config get <key>              Get a config value
  config set <key> <value>      Set a config value
  config path                   Show config file paths
  secret list                   List stored secrets
  secret set <key> <value>      Store a secret
  secret get <key>              Retrieve a secret
  secret delete <key>           Delete a secret

Extension Management:
  ext list [filter]             List available extensions
  ext search <query>            Search extensions
  ext info <name>               Show extension details
  ext install <name>            Install an extension
  ext remove <name>             Remove an extension
  ext update                    Check for updates
  ext create <name>             Scaffold a new extension
  ext validate <name>           Validate extension manifest
  ext publish <name>            Publish extension to catalog

Publishing:
  publish [--input dir] [--output dir]  Generate static site from Markdown
  publish --watch                       Watch for changes and auto-publish
  publish index                         Regenerate index only
  serve                                 Start localhost library server (port 8080)

Development:
  dev build <skill>             Build a skill container
  dev test <skill>              Test a skill
  dev logs <skill>              View skill logs
  dev shell <skill>             Enter skill container

Help:
  help                          Show this help
  version                       Show version

EOF
}

# Check if a command exists
cmd_exists() {
    command -v "$1" &>/dev/null
}

# ============================================================
# COMMAND HANDLERS
# ============================================================

cmd_script_run() {
    local file="$1"
    if [ ! -f "$file" ]; then
        error "File not found: $file"
        exit 1
    fi
    info "Running BBC BASIC script: $file"
    if cmd_exists ucode2-binder; then
        ucode2-binder "$file"
    else
        warn "ucode2-binder not found. Install with: udo setup"
        cat "$file"
    fi
}

cmd_build_run() {
    local file="$1"
    if [ ! -f "$file" ]; then
        error "File not found: $file"
        exit 1
    fi
    info "Running AMOS script: $file"
    if cmd_exists ucode2-binder; then
        ucode2-binder "$file"
    else
        warn "ucode2-binder not found. Install with: udo setup"
        cat "$file"
    fi
}

cmd_home_status() {
    info "Home Automation Status"
    if cmd_exists snackbar; then
        snackbar status 2>/dev/null || warn "Snackbar daemon not running"
    else
        warn "Snackbar not installed"
    fi
    echo "  Vault: $(ls -1 "$UDO_VAULT" 2>/dev/null | wc -l | tr -d ' ') entries"
    echo "  Fonts: $(ls -1 "$UDO_FONTS" 2>/dev/null | wc -l | tr -d ' ') categories"
}

cmd_space_explore() {
    local system="${1:-L500}"
    info "Exploring spatial system: $system"
    echo "  System: $system"
    echo "  Status: Planning phase"
    echo "  Use 'udo surface open ucode4' for 3D view"
}

cmd_surface_list() {
    info "Available Surfaces"
    echo "  ucode1  - BBC BASIC Teletext"
    echo "  ucode2  - AMOS Sprite/BOB"
    echo "  ucode3  - Home Automation"
    echo "  ucode4  - Spatial/3D (planning)"
}

cmd_surface_open() {
    local name="$1"
    info "Opening surface: $name"
    case "$name" in
        ucode1|ucode2|ucode3|ucode4)
            if [ -f "$UDO_UI/index.html" ]; then
                open "$UDO_UI/index.html#/surface/$name" 2>/dev/null || \
                    echo "  Open http://localhost:5173/#/surface/$name in browser"
            else
                warn "udoui not built yet. Run: udo setup"
            fi
            ;;
        *)
            error "Unknown surface: $name. Try: ucode1, ucode2, ucode3, ucode4"
            exit 1
            ;;
    esac
}

cmd_snack_list() {
    info "Available Snacks"
    if cmd_exists snackbar; then
        snackbar snack list 2>/dev/null || echo "  (run 'snackbar' to start daemon)"
    else
        warn "Snackbar not installed"
        echo "  Install with: udo setup"
    fi
}

cmd_snack_install() {
    local name="$1"
    info "Installing snack: $name"
    if cmd_exists snackbar; then
        snackbar snack install "$name" 2>/dev/null || warn "Snack '$name' not found in catalog"
    else
        warn "Snackbar not installed"
    fi
}

cmd_snack_run() {
    local name="$1"
    info "Running snack: $name"
    if cmd_exists snackbar; then
        snackbar snack run "$name" 2>/dev/null || warn "Failed to run snack '$name'"
    else
        warn "Snackbar not installed"
    fi
}

cmd_vault_list() {
    info "Vault Contents"
    if [ -d "$UDO_VAULT" ]; then
        echo "  Location: $UDO_VAULT"
        echo "  Entries:"
        for dir in "$UDO_VAULT"/*/; do
            [ -d "$dir" ] && echo "    - $(basename "$dir")"
        done
    else
        warn "Vault not found at $UDO_VAULT"
    fi
}

cmd_vault_sync() {
    info "Syncing Vault..."
    if [ -f "$UDO_HOME/../Usync/bin/sync-all.sh" ]; then
        bash "$UDO_HOME/../Usync/bin/sync-all.sh"
    else
        warn "Vault sync script not found"
    fi
}

cmd_vault_backup() {
    local backup_dir="${1:-$HOME/Vault/backups}"
    info "Backing up Vault to $backup_dir"
    mkdir -p "$backup_dir"
    local timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="$backup_dir/vault-$timestamp.tar.gz"
    tar -czf "$backup_file" -C "$(dirname "$UDO_VAULT")" "$(basename "$UDO_VAULT")" 2>/dev/null && \
        ok "Backup created: $backup_file" || \
        error "Backup failed"
}

cmd_font_list() {
    info "Available Fonts"
    if [ -f "$UDO_FONTS/catalogue.json" ]; then
        cat "$UDO_FONTS/catalogue.json" | python3 -m json.tool 2>/dev/null || cat "$UDO_FONTS/catalogue.json"
    else
        warn "Font catalogue not found"
        echo "  Categories:"
        for dir in "$UDO_FONTS"/*/; do
            [ -d "$dir" ] && echo "    - $(basename "$dir") ($(ls "$dir" | wc -l | tr -d ' ') fonts)"
        done
    fi
}

cmd_font_install() {
    local name="$1"
    info "Installing font: $name"
    if [ -f "$UDO_FONTS/catalogue.json" ]; then
        python3 -c "
import json, sys, os
with open('$UDO_FONTS/catalogue.json') as f:
    cat = json.load(f)
for category, fonts in cat.items():
    if isinstance(fonts, dict):
        for fname, finfo in fonts.items():
            if fname == '$name' or (isinstance(finfo, dict) and finfo.get('name') == '$name'):
                print(f'Found: {fname} in {category}')
                sys.exit(0)
print('Font not found: $name')
sys.exit(1)
" 2>/dev/null || warn "Font '$name' not found in catalogue"
    else
        warn "Font catalogue not found"
    fi
}

cmd_status() {
    info "udo System Status"
    echo "  Version:    $UDO_VERSION"
    echo "  UDO_HOME:   $UDO_HOME"
    echo "  UDO_UI:     $UDO_UI"
    echo "  UDO_VAULT:  $UDO_VAULT"
    echo ""
    echo "  Tools:"
    for tool in snackbar sonic node python3 go cargo docker; do
        if cmd_exists "$tool"; then
            ok "$tool: $(command -v "$tool")"
        else
            warn "$tool: not found"
        fi
    done
}

cmd_ui() {
    info "Launching udoui..."
    if [ -d "$UDO_UI" ]; then
        cd "$UDO_UI"
        if cmd_exists npm; then
            npm run dev 2>/dev/null || npm start 2>/dev/null || {
                warn "No dev script found. Opening static files..."
                open index.html 2>/dev/null || echo "  Open $UDO_UI/index.html in browser"
            }
        else
            warn "npm not found"
        fi
    else
        warn "udoui not found at $UDO_UI"
        echo "  Run 'udo setup' to install"
    fi
}

cmd_setup() {
    info "Setting up uDos ecosystem..."
    
    # Create necessary directories
    mkdir -p "$UDO_HOME"/{fonts,skills,surfaces,themes}
    
    # Check for npm dependencies
    if [ -d "$UDO_UI" ] && [ -f "$UDO_UI/package.json" ]; then
        info "Installing udoui dependencies..."
        cd "$UDO_UI" && npm install 2>/dev/null && ok "udoui dependencies installed" || warn "npm install failed"
    fi
    
    ok "Setup complete"
    echo ""
    echo "  Next steps:"
    echo "    - Add 'export PATH=\$PATH:$UDO_HOME/bin' to your ~/.zshrc"
    echo "    - Run 'udo status' to verify"
    echo "    - Run 'udo ui' to launch the interface"
}

cmd_init() {
    local project="$1"
    info "Scaffolding project: $project"
    local target="${2:-$HOME/Code/$project}"
    mkdir -p "$target"/{src,config,docs}
    cat > "$target/README.md" <<EOF
# $project

Scaffolded by udo init

## Structure
- \`src/\` - Source code
- \`config/\` - Configuration
- \`docs/\` - Documentation
EOF
    ok "Project created at $target"
}

# ─── Process Management ──────────────────────────────────────────
# Round 1: Startup & Process Management
# Provides: start, stop, restart, status for all uDos services

UDO_PID_DIR="${UDO_PID_DIR:-$HOME/.local/share/udos/pids}"
UDO_LOG_DIR="${UDO_LOG_DIR:-$HOME/.local/share/udos/logs}"
SNACKBAR_BIN="${SNACKBAR_BIN:-snackbar}"

cmd_start() {
    info "Starting uDos services..."
    mkdir -p "$UDO_PID_DIR" "$UDO_LOG_DIR"

    # Validate dependencies
    local missing=0
    for dep in snackbar python3 node npm; do
        if ! cmd_exists "$dep"; then
            warn "Dependency not found: $dep"
            missing=$((missing + 1))
        fi
    done

    if [ $missing -gt 0 ]; then
        warn "$missing dependencies missing — some services may not start"
    fi

    # Start Snackbar daemon
    if cmd_exists snackbar; then
        if [ -f "$UDO_PID_DIR/snackbar.pid" ]; then
            local existing_pid
            existing_pid=$(cat "$UDO_PID_DIR/snackbar.pid" 2>/dev/null)
            if kill -0 "$existing_pid" 2>/dev/null; then
                ok "Snackbar already running (PID $existing_pid)"
            else
                rm -f "$UDO_PID_DIR/snackbar.pid"
                _start_snackbar
            fi
        else
            _start_snackbar
        fi
    else
        warn "Snackbar not installed — skipping daemon"
    fi

    # Start UI servers (if in uConnect project)
    if [ -f "$HOME/Code/uConnect/scripts/udoserver.sh" ]; then
        info "Starting UI servers..."
        bash "$HOME/Code/uConnect/scripts/udoserver.sh" start 2>/dev/null || \
            warn "UI server start failed (may already be running)"
    fi

    ok "uDos services started"
    echo ""
    echo "  Run 'udo status' to verify"
}

_start_snackbar() {
    local log_file="$UDO_LOG_DIR/snackbar.log"
    nohup snackbar --daemon > "$log_file" 2>&1 &
    local pid=$!
    echo "$pid" > "$UDO_PID_DIR/snackbar.pid"

    # Wait for it to be ready (up to 10 seconds)
    local waited=0
    while [ $waited -lt 10 ]; do
        if snackbar health >/dev/null 2>&1; then
            ok "Snackbar started (PID $pid)"
            return 0
        fi
        sleep 0.5
        waited=$((waited + 1))
    done
    warn "Snackbar started (PID $pid) but not yet responding"
}

cmd_stop() {
    info "Stopping uDos services..."

    # Stop Snackbar
    if [ -f "$UDO_PID_DIR/snackbar.pid" ]; then
        local pid
        pid=$(cat "$UDO_PID_DIR/snackbar.pid" 2>/dev/null)
        if kill -0 "$pid" 2>/dev/null; then
            echo -n "  Stopping Snackbar (PID $pid)... "
            kill "$pid" 2>/dev/null || true
            local waited=0
            while [ $waited -lt 5 ]; do
                if ! kill -0 "$pid" 2>/dev/null; then break; fi
                sleep 0.3
                waited=$((waited + 1))
            done
            if kill -0 "$pid" 2>/dev/null; then
                kill -9 "$pid" 2>/dev/null || true
                echo "killed -9"
            else
                echo "stopped"
            fi
        else
            echo "  Snackbar not running (stale PID)"
        fi
        rm -f "$UDO_PID_DIR/snackbar.pid"
    else
        # Try to find and kill any snackbar process
        local snackbar_pid
        snackbar_pid=$(pgrep -x snackbar 2>/dev/null || true)
        if [ -n "$snackbar_pid" ]; then
            echo -n "  Stopping Snackbar (PID $snackbar_pid)... "
            kill "$snackbar_pid" 2>/dev/null || true
            sleep 1
            kill -9 "$snackbar_pid" 2>/dev/null || true
            echo "stopped"
        else
            echo "  Snackbar not running"
        fi
    fi

    # Stop UI servers
    if [ -f "$HOME/Code/uConnect/scripts/udoserver.sh" ]; then
        bash "$HOME/Code/uConnect/scripts/udoserver.sh" stop 2>/dev/null || true
    fi

    ok "uDos services stopped"
}

cmd_restart() {
    info "Restarting uDos services..."
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    info "uDos System Status"
    echo "  Version:    $UDO_VERSION"
    echo "  PID dir:    $UDO_PID_DIR"
    echo "  Log dir:    $UDO_LOG_DIR"
    echo ""

    # Snackbar status
    if [ -f "$UDO_PID_DIR/snackbar.pid" ]; then
        local pid
        pid=$(cat "$UDO_PID_DIR/snackbar.pid" 2>/dev/null)
        if kill -0 "$pid" 2>/dev/null; then
            ok "Snackbar: running (PID $pid)"
        else
            warn "Snackbar: stale PID file (PID $pid not running)"
        fi
    else
        local snackbar_pid
        snackbar_pid=$(pgrep -x snackbar 2>/dev/null || true)
        if [ -n "$snackbar_pid" ]; then
            warn "Snackbar: running (PID $snackbar_pid) but no PID file"
        else
            info "Snackbar: not running"
        fi
    fi

    # UI server status
    if [ -f "$HOME/Code/uConnect/scripts/udoserver.sh" ]; then
        bash "$HOME/Code/uConnect/scripts/udoserver.sh" status 2>/dev/null || true
    fi

    # Tool availability
    echo ""
    echo "  Tools:"
    for tool in snackbar python3 node npm docker cargo go; do
        if cmd_exists "$tool"; then
            ok "$tool: $(command -v "$tool")"
        else
            warn "$tool: not found"
        fi
    done
}

cmd_dev() {
    local action="${1:-status}"
    case "$action" in
        start)
            touch "$HOME/.udos/dev_mode"
            ok "Dev mode enabled"
            ;;
        stop)
            rm -f "$HOME/.udos/dev_mode"
            ok "Dev mode disabled"
            ;;
        status)
            if [ -f "$HOME/.udos/dev_mode" ]; then
                ok "Dev mode: ON"
            else
                info "Dev mode: OFF"
            fi
            ;;
        *)
            error "Unknown dev action: $action. Try: start, stop, status"
            exit 1
            ;;
    esac
}

cmd_skill_list() {
    info "Available Skills"
    if [ -d "$UDO_SKILLS" ]; then
        for skill in "$UDO_SKILLS"/*/; do
            [ -d "$skill" ] && echo "  - $(basename "$skill")"
        done
    else
        warn "No skills directory at $UDO_SKILLS"
    fi
}

cmd_skill_run() {
    local name="$1"
    local skill_dir="$UDO_SKILLS/$name"
    if [ -d "$skill_dir" ]; then
        if [ -f "$skill_dir/run.sh" ]; then
            info "Running skill: $name"
            bash "$skill_dir/run.sh" "${@:2}"
        elif [ -f "$skill_dir/skill.yaml" ]; then
            info "Skill definition found: $name"
            cat "$skill_dir/skill.yaml"
        else
            warn "No run script found for skill: $name"
        fi
    else
        error "Skill not found: $name"
        exit 1
    fi
}

# ─── Core Automation ─────────────────────────────────────────────
# Round 3: Unified Command Layer
# Provides: run, task, agent, mcp, upgraded surface/vault

# ─── Run (Skill/Snack/Spice) ─────────────────────────────────────
cmd_run() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo run <skill> [--params]"
        echo "  Runs a skill, snack, or spice (containerised action)"
        echo "  Skills:  persistent, user-installed (e.g., 'translate-to-spanish')"
        echo "  Snacks:  session-only, temporary (e.g., 'summarize-this')"
        echo "  Spices:  system-level, pre-installed (e.g., 'save-to-vault')"
        exit 1
    fi

    # Check if it's a skill first
    if [ -d "$UDO_SKILLS/$name" ]; then
        cmd_skill_run "$@"
        return
    fi

    # Check if snackbar can run it
    if cmd_exists snackbar; then
        snackbar snack run "$name" 2>/dev/null && return
    fi

    # Fallback: try as a containerised action
    if cmd_exists docker; then
        local image="ghcr.io/udos/$name:latest"
        if docker image inspect "$image" >/dev/null 2>&1; then
            info "Running containerised action: $name"
            docker run --rm "$image" "${@:2}"
            return
        fi
    fi

    error "Action not found: $name"
    echo "  Check: udo skill list, or install with: udo skill install $name"
    exit 1
}

# ─── Task Management ─────────────────────────────────────────────
UDO_TASK_DB="${UDO_TASK_DB:-$HOME/.local/share/udos/tasks.json}"

cmd_task_add() {
    local desc="$*"
    if [ -z "$desc" ]; then
        error "Usage: udo task add <description>"
        exit 1
    fi

    mkdir -p "$(dirname "$UDO_TASK_DB")"
    local id
    id=$(date +%s)$RANDOM
    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    python3 -c "
import json, os, sys

db_path = '$UDO_TASK_DB'
tasks = []
if os.path.exists(db_path):
    with open(db_path) as f:
        tasks = json.load(f)

task = {
    'id': '$id',
    'title': '$desc',
    'description': '',
    'status': 'pending',
    'priority': 'medium',
    'labels': [],
    'surface': 'ucode1',
    'assigned_to': None,
    'created_at': '$now',
    'completed_at': None,
    'depends_on': [],
    'on_complete': None
}
tasks.append(task)

with open(db_path, 'w') as f:
    json.dump(tasks, f, indent=2)

print('$id')
" 2>/dev/null && ok "Task created: $desc (ID: $id)" || error "Failed to create task"
}

cmd_task_list() {
    local status_filter=""
    local priority_filter=""

    # Parse --status and --priority flags
    while [ $# -gt 0 ]; do
        case "$1" in
            --status) status_filter="$2"; shift 2 ;;
            --priority|--pri) priority_filter="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ ! -f "$UDO_TASK_DB" ]; then
        info "No tasks yet. Create one with: udo task add <description>"
        return
    fi

    python3 -c "
import json, sys

with open('$UDO_TASK_DB') as f:
    tasks = json.load(f)

status_filter = '$status_filter'
priority_filter = '$priority_filter'

# Apply filters
if status_filter:
    tasks = [t for t in tasks if t.get('status') == status_filter]
if priority_filter:
    tasks = [t for t in tasks if t.get('priority') == priority_filter]

if not tasks:
    print('No tasks match filters')
    sys.exit(0)

# Surface-aware rendering
for t in tasks:
    status_char = {
        'pending': '☐',
        'in_progress': '▶',
        'completed': '✓',
        'blocked': '⊘',
        'archived': '◻'
    }.get(t.get('status', 'pending'), '☐')

    pri = t.get('priority', 'medium')
    pri_display = {
        'low': '[LOW] ',
        'medium': '[MED] ',
        'high': '[HIGH]',
        'critical': '[CRIT]'
    }.get(pri, '[MED] ')

    surface = t.get('surface', '')
    surface_tag = f'({surface})' if surface else ''

    print(f\"  {status_char} [{t['id'][:8]}] {t['title']:50s} {pri_display} {surface_tag}\")
    labels = t.get('labels', [])
    if labels:
        print(f\"  {'':12s} tags: {', '.join(labels)}\")
" 2>/dev/null || warn "Failed to read tasks"
}

cmd_task_show() {
    local id="$1"
    if [ -z "$id" ]; then
        error "Usage: udo task show <id>"
        exit 1
    fi

    if [ ! -f "$UDO_TASK_DB" ]; then
        error "No tasks found"
        exit 1
    fi

    python3 -c "
import json, sys

with open('$UDO_TASK_DB') as f:
    tasks = json.load(f)

for t in tasks:
    if t['id'].startswith('$id') or t['id'] == '$id':
        print(f\"  ID:          {t['id']}\")
        print(f\"  Title:       {t['title']}\")
        print(f\"  Status:      {t.get('status', 'pending')}\")
        print(f\"  Priority:    {t.get('priority', 'medium')}\")
        print(f\"  Surface:     {t.get('surface', 'ucode1')}\")
        print(f\"  Assigned:    {t.get('assigned_to', 'unassigned')}\")
        print(f\"  Created:     {t.get('created_at', 'unknown')}\")
        print(f\"  Completed:   {t.get('completed_at', '—')}\")
        labels = t.get('labels', [])
        if labels:
            print(f\"  Labels:      {', '.join(labels)}\")
        deps = t.get('depends_on', [])
        if deps:
            print(f\"  Depends on:  {', '.join(deps)}\")
        on_complete = t.get('on_complete')
        if on_complete:
            print(f\"  On complete: {on_complete.get('action')} {on_complete.get('skill', '')}\")
        sys.exit(0)

print('Task not found: $id')
sys.exit(1)
" 2>/dev/null || error "Task not found: $id"
}

cmd_task_do() {
    local id="$1"
    if [ -z "$id" ]; then
        error "Usage: udo task do <id>"
        exit 1
    fi

    local now
    now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    python3 -c "
import json, os, sys

with open('$UDO_TASK_DB') as f:
    tasks = json.load(f)

found = False
for t in tasks:
    if t['id'].startswith('$id') or t['id'] == '$id':
        t['status'] = 'completed'
        t['completed_at'] = '$now'
        found = True
        # Trigger on_complete action
        on_complete = t.get('on_complete')
        if on_complete:
            print(f\"Trigger: {on_complete.get('action')} {on_complete.get('skill', '')}\")
        break

if found:
    with open('$UDO_TASK_DB', 'w') as f:
        json.dump(tasks, f, indent=2)
    print('ok')
else:
    print('not_found')
    sys.exit(1)
" 2>/dev/null && ok "Task $id completed" || error "Task not found: $id"
}

cmd_task_undo() {
    local id="$1"
    if [ -z "$id" ]; then
        error "Usage: udo task undo <id>"
        exit 1
    fi

    python3 -c "
import json, os, sys

with open('$UDO_TASK_DB') as f:
    tasks = json.load(f)

found = False
for t in tasks:
    if t['id'].startswith('$id') or t['id'] == '$id':
        t['status'] = 'pending'
        t['completed_at'] = None
        found = True
        break

if found:
    with open('$UDO_TASK_DB', 'w') as f:
        json.dump(tasks, f, indent=2)
    print('ok')
else:
    print('not_found')
    sys.exit(1)
" 2>/dev/null && ok "Task $id reopened" || error "Task not found: $id"
}

cmd_task_delete() {
    local id="$1"
    if [ -z "$id" ]; then
        error "Usage: udo task delete <id>"
        exit 1
    fi

    python3 -c "
import json, os, sys

with open('$UDO_TASK_DB') as f:
    tasks = json.load(f)

new_tasks = [t for t in tasks if not (t['id'].startswith('$id') or t['id'] == '$id')]

if len(new_tasks) == len(tasks):
    print('not_found')
    sys.exit(1)

with open('$UDO_TASK_DB', 'w') as f:
    json.dump(new_tasks, f, indent=2)
print('ok')
" 2>/dev/null && ok "Task $id deleted" || error "Task not found: $id"
}

cmd_task_tag() {
    local id="$1"
    local tag="$2"
    if [ -z "$id" ] || [ -z "$tag" ]; then
        error "Usage: udo task tag <id> <tag>"
        exit 1
    fi

    python3 -c "
import json, os, sys

with open('$UDO_TASK_DB') as f:
    tasks = json.load(f)

found = False
for t in tasks:
    if t['id'].startswith('$id') or t['id'] == '$id':
        labels = t.get('labels', [])
        if '$tag' not in labels:
            labels.append('$tag')
        t['labels'] = labels
        found = True
        break

if found:
    with open('$UDO_TASK_DB', 'w') as f:
        json.dump(tasks, f, indent=2)
    print('ok')
else:
    print('not_found')
    sys.exit(1)
" 2>/dev/null && ok "Tag '$tag' added to task $id" || error "Task not found: $id"
}

cmd_task_assign() {
    local id="$1"
    local assignee="$2"
    if [ -z "$id" ] || [ -z "$assignee" ]; then
        error "Usage: udo task assign <id> <agent|user>"
        exit 1
    fi

