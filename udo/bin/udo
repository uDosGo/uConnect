found = False
for t in tasks:
    if t['id'].startswith('$id') or t['id'] == '$id':
        t['assigned_to'] = '$assignee'
        found = True
        break

if found:
    with open('$UDO_TASK_DB', 'w') as f:
        json.dump(tasks, f, indent=2)
    print('ok')
else:
    print('not_found')
    sys.exit(1)
" 2>/dev/null && ok "Task $id assigned to $assignee" || error "Task not found: $id"
}

