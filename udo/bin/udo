# ─── Agent Orchestration ─────────────────────────────────────────
cmd_agent_list() {
    info "Available Agents"
    if cmd_exists snackbar; then
        snackbar agent list 2>/dev/null || echo "  (run 'snackbar' to start daemon)"
    else
        echo "  hivemind  - Multi-agent orchestrator"
        echo "  coder     - Code generation agent"
        echo "  reviewer  - Code review agent"
    fi
}

cmd_agent_call() {
    local name="$1"
    shift
    local prompt=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --prompt) prompt="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [ -z "$name" ] || [ -z "$prompt" ]; then
        error "Usage: udo agent call <name> --prompt \"...\""
        exit 1
    fi

    info "Calling agent: $name"
    if cmd_exists snackbar; then
        snackbar agent call "$name" --prompt "$prompt" 2>/dev/null || {
            warn "Agent '$name' not available via Snackbar"
            echo "  Prompt: $prompt"
        }
    else
        echo "  Agent: $name"
        echo "  Prompt: $prompt"
        echo "  (Snackbar not running — agent call logged only)"
    fi
}

cmd_agent_status() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo agent status <name>"
        exit 1
    fi

    if cmd_exists snackbar; then
        snackbar agent status "$name" 2>/dev/null || warn "Agent '$name' not found"
    else
        info "Agent '$name': unknown (Snackbar not running)"
    fi
}

cmd_agent_stop() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo agent stop <name>"
        exit 1
    fi

    if cmd_exists snackbar; then
        snackbar agent stop "$name" 2>/dev/null && ok "Agent '$name' stopped" || warn "Failed to stop agent"
    else
        warn "Snackbar not running"
    fi
}

