# ─── Vault (Upgraded) ────────────────────────────────────────────
cmd_vault_get() {
    local path="$1"
    if [ -z "$path" ]; then
        error "Usage: udo vault get <path>"
        exit 1
    fi

    local target="$UDO_VAULT/$path"
    if [ -f "$target" ]; then
        cat "$target"
    elif [ -d "$target" ]; then
        ls -la "$target"
    else
        # Try Snackbar vault
        if cmd_exists snackbar; then
            snackbar vault get "$path" 2>/dev/null && return
        fi
        error "Path not found: $path"
        exit 1
    fi
}

cmd_vault_set() {
    local path="$1"
    local value="$2"
    if [ -z "$path" ] || [ -z "$value" ]; then
        error "Usage: udo vault set <path> <value>"
        exit 1
    fi

    local target="$UDO_VAULT/$path"
    mkdir -p "$(dirname "$target")"
    echo "$value" > "$target"
    ok "Written to $path"
}

cmd_vault_watch() {
    local path="$1"
    if [ -z "$path" ]; then
        error "Usage: udo vault watch <path>"
        exit 1
    fi

    local target="$UDO_VAULT/$path"
    if [ ! -e "$target" ]; then
        warn "Path does not exist yet: $path"
        echo "  Will watch for creation..."
    fi

    info "Watching: $path (Ctrl+C to stop)"
    if cmd_exists fswatch; then
        fswatch -0 "$target" 2>/dev/null | while read -d "" event; do
            ok "Change detected: $event"
        done
    else
        # Poll-based fallback
        local last_mod=$(stat -f "%m" "$target" 2>/dev/null || echo "0")
        while true; do
            sleep 2
            local new_mod=$(stat -f "%m" "$target" 2>/dev/null || echo "0")
            if [ "$new_mod" != "$last_mod" ]; then
                ok "Change detected: $path"
                last_mod="$new_mod"
            fi
        done
    fi
}

# ─── Dev (Upgraded) ──────────────────────────────────────────────
cmd_dev_build() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo dev build <skill>"
        exit 1
    fi

    local skill_dir="$UDO_SKILLS/$name"
    if [ ! -d "$skill_dir" ]; then
        error "Skill not found: $name"
        exit 1
    fi

    if [ -f "$skill_dir/Dockerfile" ]; then
        info "Building container for skill: $name"
        docker build -t "udos/$name:latest" "$skill_dir" 2>/dev/null && \
            ok "Container built: udos/$name:latest" || \
            error "Build failed"
    else
        info "No Dockerfile found — skill is script-based"
        ok "Skill $name is ready (no build needed)"
    fi
}

cmd_dev_test() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo dev test <skill>"
        exit 1
    fi

    local skill_dir="$UDO_SKILLS/$name"
    if [ -f "$skill_dir/test.sh" ]; then
        info "Testing skill: $name"
        bash "$skill_dir/test.sh" "${@:2}"
    elif [ -f "$skill_dir/tests/" ]; then
        info "Running tests for: $name"
        for test in "$skill_dir/tests/"*; do
            [ -f "$test" ] && bash "$test"
        done
    else
        warn "No tests found for skill: $name"
    fi
}

cmd_dev_logs() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo dev logs <skill>"
        exit 1
    fi

    local log_file="$UDO_LOG_DIR/$name.log"
    if [ -f "$log_file" ]; then
        tail -f "$log_file"
    else
        warn "No logs found for: $name"
        echo "  Checked: $log_file"
    fi
}

cmd_dev_shell() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo dev shell <skill>"
        exit 1
    fi

    if cmd_exists docker; then
        local image="udos/$name:latest"
        if docker image inspect "$image" >/dev/null 2>&1; then
            info "Entering container: $name"
            docker run -it --rm "$image" /bin/bash 2>/dev/null || \
                docker run -it --rm "$image" /bin/sh 2>/dev/null || \
                warn "No shell available in container"
        else
            warn "Container not built: $name"
            echo "  Build with: udo dev build $name"
        fi
    else
        warn "Docker not available"
    fi
}

# ─── Configuration Management ────────────────────────────────────
# Round 2: Configuration & Secrets Management
# Provides: config show/get/set/path, secret list/set/get/delete

UDO_CONFIG_DIR="${UDO_CONFIG_DIR:-$HOME/.config/udos}"
UDO_CONFIG_FILE="${UDO_CONFIG_FILE:-$UDO_CONFIG_DIR/config.yaml}"
SNACKBAR_CONFIG="${SNACKBAR_CONFIG:-/etc/snackbar/config.toml}"

cmd_config_show() {
    info "uDos Configuration"
    echo ""
    echo "  Environment:"
    echo "    UDO_HOME:         $UDO_HOME"
    echo "    UDO_UI:           $UDO_UI"
    echo "    UDO_VAULT:        $UDO_VAULT"
    echo "    UDO_SKILLS:       $UDO_SKILLS"
    echo "    UDO_CONFIG_DIR:   $UDO_CONFIG_DIR"
    echo "    UDO_PID_DIR:      $UDO_PID_DIR"
    echo "    UDO_LOG_DIR:      $UDO_LOG_DIR"
    echo ""

    # Show config file if it exists
    if [ -f "$UDO_CONFIG_FILE" ]; then
        echo "  Config file ($UDO_CONFIG_FILE):"
        cat "$UDO_CONFIG_FILE" | sed 's/^/    /'
    else
        echo "  Config file: not found ($UDO_CONFIG_FILE)"
    fi
    echo ""

    # Show snackbar config if it exists
    if [ -f "$SNACKBAR_CONFIG" ]; then
        echo "  Snackbar config ($SNACKBAR_CONFIG):"
        cat "$SNACKBAR_CONFIG" | sed 's/^/    /'
    elif [ -f "./config/config.toml" ]; then
        echo "  Snackbar config (local):"
        cat "./config/config.toml" | sed 's/^/    /'
    else
        echo "  Snackbar config: not found"
    fi
}

cmd_config_get() {
    local key="$1"
    if [ -z "$key" ]; then
        error "Usage: udo config get <key>"
        exit 1
    fi

    # Check environment variables first
    local env_key="UDO_$(echo "$key" | tr '[:lower:]' '[:upper:]')"
    local env_val="${!env_key:-}"
    if [ -n "$env_val" ]; then
        ok "$key = $env_val (from environment)"
        return
    fi

    # Check config file
    if [ -f "$UDO_CONFIG_FILE" ]; then
        local val
        val=$(python3 -c "
import yaml, sys
with open('$UDO_CONFIG_FILE') as f:
    config = yaml.safe_load(f) or {}
keys = '$key'.split('.')
val = config
for k in keys:
    if isinstance(val, dict):
        val = val.get(k)
    else:
        val = None
        break
if val is not None:
    print(val)
else:
    sys.exit(1)
" 2>/dev/null) && {
            ok "$key = $val (from config file)"
            return
        }
    fi

    warn "$key: not set"
}

cmd_config_set() {
    local key="$1"
    local value="$2"
    if [ -z "$key" ] || [ -z "$value" ]; then
        error "Usage: udo config set <key> <value>"
        exit 1
    fi

    mkdir -p "$UDO_CONFIG_DIR"

    # Use python3 to update YAML config
    python3 -c "
import yaml, os, sys

config_file = '$UDO_CONFIG_FILE'
key = '$key'
value = '$value'

# Load existing config
config = {}
if os.path.exists(config_file):
    with open(config_file) as f:
        config = yaml.safe_load(f) or {}

# Set nested key (e.g., 'server.port' -> config['server']['port'])
keys = key.split('.')
current = config
for k in keys[:-1]:
    if k not in current:
        current[k] = {}
    current = current[k]
current[keys[-1]] = value

# Write back
with open(config_file, 'w') as f:
    yaml.dump(config, f, default_flow_style=False)

print('ok')
" 2>/dev/null && ok "$key = $value" || error "Failed to set $key"
}

cmd_config_path() {
    info "Configuration File Paths"
    echo "  uDos config:     $UDO_CONFIG_FILE"
    echo "  Snackbar config: $SNACKBAR_CONFIG"
    echo "  PID directory:   $UDO_PID_DIR"
    echo "  Log directory:   $UDO_LOG_DIR"
    echo "  Skills:          $UDO_SKILLS"
    echo "  Extensions:      $UDO_EXTENSIONS"
    echo "  Extension reg:   $UDO_EXT_REGISTRY"
}

# ─── Secret Management ──────────────────────────────────────────
