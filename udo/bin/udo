cmd_secret_list() {
    info "Stored Secrets"
    if cmd_exists snackbar; then
        snackbar secret list 2>/dev/null || {
            warn "Snackbar not running — secrets unavailable"
            echo "  Start with: udo start"
        }
    else
        warn "Snackbar not installed"
    fi
}

cmd_secret_set() {
    local key="$1"
    local value="$2"
    if [ -z "$key" ] || [ -z "$value" ]; then
        error "Usage: udo secret set <key> <value>"
        exit 1
    fi

    if cmd_exists snackbar; then
        snackbar secret set "$key" "$value" 2>/dev/null && \
            ok "Secret '$key' stored" || \
            warn "Failed to store secret (is Snackbar running?)"
    else
        warn "Snackbar not installed"
    fi
}

cmd_secret_get() {
    local key="$1"
    if [ -z "$key" ]; then
        error "Usage: udo secret get <key>"
        exit 1
    fi

    if cmd_exists snackbar; then
        local val
        val=$(snackbar secret get "$key" 2>/dev/null) && {
            echo "$val"
        } || {
            warn "Secret '$key' not found (is Snackbar running?)"
        }
    else
        warn "Snackbar not installed"
    fi
}

cmd_secret_delete() {
    local key="$1"
    if [ -z "$key" ]; then
        error "Usage: udo secret delete <key>"
        exit 1
    fi

    if cmd_exists snackbar; then
        snackbar secret delete "$key" 2>/dev/null && \
            ok "Secret '$key' deleted" || \
            warn "Failed to delete secret (is Snackbar running?)"
    else
        warn "Snackbar not installed"
    fi
}

# ============================================================
# EXTENSION MANAGEMENT (udo ext)
# ============================================================

cmd_ext_list() {
    local filter="${1:-}"
    if [ ! -f "$UDO_EXTENSIONS/catalog/index.json" ]; then
        error "Extension catalog not found at $UDO_EXTENSIONS/catalog/index.json"
        exit 1
    fi
    info "Extension Catalog"
    echo ""
    python3 -c "
import json, sys
with open('$UDO_EXTENSIONS/catalog/index.json') as f:
    catalog = json.load(f)
exts = catalog.get('extensions', [])
if '$filter':
    exts = [e for e in exts if '$filter' in e.get('tags', []) or '$filter' in e.get('categories', []) or '$filter' in e.get('name', '')]
print(f'Total: {len(exts)} extensions')
print('')
for ext in exts:
    tags = ', '.join(ext.get('tags', [])[:3])
    print(f\"  {ext['name']:35s} {ext['version']:8s} {ext['type']:12s} {ext['displayName']}\")
    print(f\"  {'':35s} {'':8s} {'':12s} {ext.get('description', '')}\")
    if tags:
        print(f\"  {'':35s} {'':8s} {'':12s} tags: {tags}\")
    print('')
" 2>/dev/null || {
        warn "Failed to parse catalog (python3 required)"
        cat "$UDO_EXTENSIONS/catalog/index.json" | head -50
    }
}

cmd_ext_search() {
    local query="$1"
    if [ -z "$query" ]; then
        error "Usage: udo ext search <query>"
        exit 1
    fi
    info "Searching for: $query"
    cmd_ext_list "$query"
}

cmd_ext_info() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo ext info <name>"
        exit 1
    fi
    # Check manifest first, then catalog
    local manifest="$UDO_EXTENSIONS/manifests/$name.json"
    if [ -f "$manifest" ]; then
        info "Extension: $name"
        python3 -c "
import json, sys
with open('$manifest') as f:
    m = json.load(f)
print(f\"  Name:        {m.get('name', 'N/A')}\")
print(f\"  Version:     {m.get('version', 'N/A')}\")
print(f\"  Type:        {m.get('type', 'N/A')}\")
print(f\"  Display:     {m.get('displayName', 'N/A')}\")
print(f\"  Description: {m.get('description', 'N/A')}\")
print(f\"  Author:      {m.get('author', 'N/A')}\")
print(f\"  License:     {m.get('license', 'N/A')}\")
print(f\"  Platform:    {m.get('platform', 'N/A')}\")
print(f\"  Entry:       {m.get('entry', 'N/A')}\")
print(f\"  Size:        {m.get('size', 'N/A')}\")
deps = m.get('dependencies', {})
if deps:
    print(f\"  Dependencies:\")
    for pkg, ver in deps.items():
        print(f\"    - {pkg}: {ver}\")
surfaces = m.get('surfaces', [])
if surfaces:
    print(f\"  Surfaces:    {', '.join(surfaces)}\")
tags = m.get('tags', [])
if tags:
    print(f\"  Tags:        {', '.join(tags)}\")
config = m.get('config', {})
if config:
    print(f\"  Config:\")
    for key, val in config.items():
        print(f\"    {key}: {val}\")
" 2>/dev/null
    else
        # Fall back to catalog
        if [ ! -f "$UDO_EXTENSIONS/catalog/index.json" ]; then
            error "Catalog not found"
            exit 1
        fi
        python3 -c "
import json, sys
with open('$UDO_EXTENSIONS/catalog/index.json') as f:
    catalog = json.load(f)
for ext in catalog.get('extensions', []):
    if ext['name'] == '$name':
        print(json.dumps(ext, indent=2))
        sys.exit(0)
print('Extension not found: $name')
sys.exit(1)
" 2>/dev/null || error "Extension '$name' not found in catalog"
    fi
}

cmd_ext_install() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo ext install <name>"
        exit 1
    fi
    # Check if extension exists in catalog
    if [ ! -f "$UDO_EXTENSIONS/catalog/index.json" ]; then
        error "Catalog not found"
        exit 1
    fi
    local found=$(python3 -c "
import json, sys
with open('$UDO_EXTENSIONS/catalog/index.json') as f:
    catalog = json.load(f)
for ext in catalog.get('extensions', []):
    if ext['name'] == '$name':
        print('yes')
        sys.exit(0)
print('no')
" 2>/dev/null)
    if [ "$found" != "yes" ]; then
        error "Extension '$name' not found in catalog"
        echo "  Run 'udo ext list' to see available extensions"
        exit 1
    fi
    # Create registry entry
    mkdir -p "$UDO_EXT_REGISTRY/$name"
    local reg_entry="$UDO_EXT_REGISTRY/$name/registry.json"
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    cat > "$reg_entry" <<REGEOF
{
  "name": "$name",
  "installedAt": "$timestamp",
  "version": "latest",
  "status": "installed"
}
REGEOF
    # Update registry index
    local reg_index="$UDO_EXTENSIONS/registry/index.json"
    if [ -f "$reg_index" ]; then
        python3 -c "
import json
with open('$reg_index') as f:
    reg = json.load(f)
installed = reg.get('installed', [])
if '$name' not in installed:
    installed.append('$name')
    reg['installed'] = installed
    reg['lastUpdated'] = '$timestamp'
with open('$reg_index', 'w') as f:
    json.dump(reg, f, indent=2)
" 2>/dev/null
    fi
    ok "Extension '$name' installed"
    echo "  Registry: $UDO_EXT_REGISTRY/$name/"
    echo "  Run 'udo ext info $name' for details"
}

cmd_ext_remove() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo ext remove <name>"
        exit 1
    fi
    if [ ! -d "$UDO_EXT_REGISTRY/$name" ]; then
        error "Extension '$name' is not installed"
        exit 1
    fi
    rm -rf "$UDO_EXT_REGISTRY/$name"
    # Update registry index
    local reg_index="$UDO_EXTENSIONS/registry/index.json"
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    if [ -f "$reg_index" ]; then
        python3 -c "
import json
with open('$reg_index') as f:
    reg = json.load(f)
installed = reg.get('installed', [])
if '$name' in installed:
    installed.remove('$name')
    reg['installed'] = installed
    reg['lastUpdated'] = '$timestamp'
with open('$reg_index', 'w') as f:
    json.dump(reg, f, indent=2)
" 2>/dev/null
    fi
    ok "Extension '$name' removed"
}

cmd_ext_update() {
    info "Checking for updates..."
    local reg_index="$UDO_EXTENSIONS/registry/index.json"
    if [ ! -f "$reg_index" ]; then
        warn "No extensions installed"
        return
    fi
    local installed=$(python3 -c "
import json
with open('$reg_index') as f:
    reg = json.load(f)
for ext in reg.get('installed', []):
    print(ext)
" 2>/dev/null)
    if [ -z "$installed" ]; then
        info "No extensions to update"
        return
    fi
    echo "  Installed extensions:"
    echo "$installed" | while IFS= read -r ext; do
        echo "    - $ext (up-to-date)"
    done
    ok "Update check complete"
}

cmd_ext_create() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo ext create <name>"
        exit 1
    fi
    local manifest="$UDO_EXTENSIONS/manifests/$name.json"
    if [ -f "$manifest" ]; then
        error "Extension '$name' already exists"
        exit 1
    fi
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    cat > "$manifest" <<MANEOF
{
  "name": "$name",
  "version": "0.1.0",
  "type": "tool",
  "displayName": "$name",
  "description": "Description of $name",
  "author": "uDosGo",
  "license": "MIT",
  "platform": "linux",
  "surfaces": [],
  "tags": [],
  "categories": [],
  "entry": "",
  "config": {},
  "size": "0.1 MB"
}
MANEOF
    ok "Extension scaffold created: $manifest"
    echo "  Edit the manifest to add details"
    echo "  Run 'udo ext validate $name' to check"
}

cmd_ext_validate() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo ext validate <name>"
        exit 1
    fi
    local manifest="$UDO_EXTENSIONS/manifests/$name.json"
    if [ ! -f "$manifest" ]; then
        error "Manifest not found: $manifest"
        exit 1
    fi
    info "Validating: $name"
    local errors=0
    # Check required fields
    for field in name version type displayName description; do
        local val=$(python3 -c "
import json, sys
with open('$manifest') as f:
    m = json.load(f)
print(m.get('$field', ''))
" 2>/dev/null)
        if [ -z "$val" ]; then
            error "  Missing required field: $field"
            errors=$((errors + 1))
        fi
    done
    # Check version format
    local version=$(python3 -c "
import json, sys
with open('$manifest') as f:
    m = json.load(f)
print(m.get('version', ''))
" 2>/dev/null)
    if ! echo "$version" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
        error "  Invalid version format: $version (expected semver)"
        errors=$((errors + 1))
    fi
    # Check type
    local type=$(python3 -c "
import json, sys
with open('$manifest') as f:
    m = json.load(f)
print(m.get('type', ''))
" 2>/dev/null)
    case "$type" in
        skill|surface|service|integration|theme|tool) ;;
        *)
            error "  Invalid type: $type (expected: skill, surface, service, integration, theme, tool)"
            errors=$((errors + 1))
            ;;

    esac
    if [ "$errors" -eq 0 ]; then
        ok "Manifest is valid"
    else
        error "Found $errors error(s)"
        exit 1
    fi
}

cmd_ext_publish() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Usage: udo ext publish <name>"
        exit 1
    fi
    local manifest="$UDO_EXTENSIONS/manifests/$name.json"
    if [ ! -f "$manifest" ]; then
        error "Manifest not found: $manifest"
        echo "  Create one with: udo ext create $name"
        exit 1
    fi
    # Validate first
    cmd_ext_validate "$name" || exit 1
    # Add to catalog
    local catalog="$UDO_EXTENSIONS/catalog/index.json"
    if [ ! -f "$catalog" ]; then
        error "Catalog not found"
        exit 1
    fi
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    python3 -c "
import json, sys
with open('$manifest') as f:
    m = json.load(f)
with open('$catalog') as f:
    cat = json.load(f)
# Check if already exists
exts = cat.get('extensions', [])
for i, ext in enumerate(exts):
    if ext['name'] == '$name':
        exts[i] = m
        break
else:
    exts.append(m)
cat['extensions'] = exts
cat['totalExtensions'] = len(exts)
cat['lastUpdated'] = '$timestamp'
with open('$catalog', 'w') as f:
    json.dump(cat, f, indent=2)
print('ok')
" 2>/dev/null && ok "Extension '$name' published to catalog" || error "Failed to publish"
}

# ============================================================
# MAIN
# ============================================================

main() {

    if [ $# -eq 0 ]; then
        usage
        exit 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        help|--help|-h)
            usage
            ;;
        version|--version|-v)
            echo "udo v${UDO_VERSION}"
            ;;
        script)
            [ $# -lt 1 ] && { error "Usage: udo script run <file>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                run) cmd_script_run "$@" ;;
                *) error "Unknown script subcommand: $sub"; exit 1 ;;
            esac
            ;;
        build)
            [ $# -lt 1 ] && { error "Usage: udo build run <file>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                run) cmd_build_run "$@" ;;
                *) error "Unknown build subcommand: $sub"; exit 1 ;;
            esac
            ;;
        home)
            [ $# -lt 1 ] && { error "Usage: udo home status"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                status) cmd_home_status ;;
                *) error "Unknown home subcommand: $sub"; exit 1 ;;
            esac
            ;;
        space)
            [ $# -lt 1 ] && { error "Usage: udo space explore <system>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                explore) cmd_space_explore "$@" ;;
                *) error "Unknown space subcommand: $sub"; exit 1 ;;
            esac
            ;;
        run)
            cmd_run "$@"
            ;;
        task)
            [ $# -lt 1 ] && { error "Usage: udo task <add|list|show|do|undo|delete|tag|assign>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                add) cmd_task_add "$@" ;;
                list) cmd_task_list "$@" ;;
                show) cmd_task_show "$@" ;;
                do) cmd_task_do "$@" ;;
                undo) cmd_task_undo "$@" ;;
                delete) cmd_task_delete "$@" ;;
                tag) cmd_task_tag "$@" ;;
                assign) cmd_task_assign "$@" ;;
                *) error "Unknown task subcommand: $sub"; exit 1 ;;
            esac
            ;;
        agent)
            [ $# -lt 1 ] && { error "Usage: udo agent <list|call|status|stop>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                list) cmd_agent_list ;;
                call) cmd_agent_call "$@" ;;
                status) cmd_agent_status "$@" ;;
                stop) cmd_agent_stop "$@" ;;
                *) error "Unknown agent subcommand: $sub"; exit 1 ;;
            esac
            ;;
        mcp)
            [ $# -lt 1 ] && { error "Usage: udo mcp <list|call|server>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                list) cmd_mcp_list ;;
                call) cmd_mcp_call "$@" ;;
                server)
                    [ $# -lt 1 ] && { error "Usage: udo mcp server <start|stop> <name>"; exit 1; }
                    local action="$1"; shift
                    case "$action" in
                        start) cmd_mcp_server_start "$@" ;;
                        stop) cmd_mcp_server_stop "$@" ;;
                        *) error "Unknown mcp server action: $action"; exit 1 ;;
                    esac
                    ;;
                *) error "Unknown mcp subcommand: $sub"; exit 1 ;;
            esac
            ;;
        surface)
            [ $# -lt 1 ] && { error "Usage: udo surface <list|open|close|focus>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                list) cmd_surface_list ;;
                open) cmd_surface_open "$@" ;;
                close) cmd_surface_close "$@" ;;
                focus) cmd_surface_focus "$@" ;;
                *) error "Unknown surface subcommand: $sub"; exit 1 ;;
            esac
            ;;
        snack)
            [ $# -lt 1 ] && { error "Usage: udo snack <list|install|run>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                list) cmd_snack_list ;;
                install) cmd_snack_install "$@" ;;
                run) cmd_snack_run "$@" ;;
                *) error "Unknown snack subcommand: $sub"; exit 1 ;;
            esac
            ;;
        vault)
            [ $# -lt 1 ] && { error "Usage: udo vault <get|set|list|watch|sync|backup>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                get) cmd_vault_get "$@" ;;
                set) cmd_vault_set "$@" ;;
                list) cmd_vault_list ;;
                watch) cmd_vault_watch "$@" ;;
                sync) cmd_vault_sync ;;
                backup) cmd_vault_backup "$@" ;;
                *) error "Unknown vault subcommand: $sub"; exit 1 ;;
            esac
            ;;
        font)
            [ $# -lt 1 ] && { error "Usage: udo font <list|install>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                list) cmd_font_list ;;
                install) cmd_font_install "$@" ;;
                *) error "Unknown font subcommand: $sub"; exit 1 ;;
            esac
            ;;
        status)
            cmd_status
            ;;
        ui)
            cmd_ui
            ;;
        setup)
            cmd_setup
            ;;
        init)
            cmd_init "$@"
            ;;
        start)
            cmd_start "$@"
            ;;
        stop)
            cmd_stop "$@"
            ;;
        restart)
            cmd_restart "$@"
            ;;
        dev)
            cmd_dev "$@"
            ;;
        config)
            [ $# -lt 1 ] && { error "Usage: udo config <show|get|set|path>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                show) cmd_config_show ;;
                get) cmd_config_get "$@" ;;
                set) cmd_config_set "$@" ;;
                path) cmd_config_path ;;
                *) error "Unknown config subcommand: $sub"; exit 1 ;;
            esac
            ;;
        secret)
            [ $# -lt 1 ] && { error "Usage: udo secret <list|set|get|delete>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                list) cmd_secret_list ;;
                set) cmd_secret_set "$@" ;;
                get) cmd_secret_get "$@" ;;
                delete) cmd_secret_delete "$@" ;;
                *) error "Unknown secret subcommand: $sub"; exit 1 ;;
            esac
            ;;
        ext)
            [ $# -lt 1 ] && { error "Usage: udo ext <list|search|info|install|remove|update|create|validate|publish>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                list) cmd_ext_list "$@" ;;
                search) cmd_ext_search "$@" ;;
                info) cmd_ext_info "$@" ;;
                install) cmd_ext_install "$@" ;;
                remove) cmd_ext_remove "$@" ;;
                update) cmd_ext_update ;;
                create) cmd_ext_create "$@" ;;
                validate) cmd_ext_validate "$@" ;;
                publish) cmd_ext_publish "$@" ;;
                *) error "Unknown ext subcommand: $sub"; exit 1 ;;
            esac
            ;;
        skill)
            [ $# -lt 1 ] && { error "Usage: udo skill <list|run>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                list) cmd_skill_list ;;
                run) cmd_skill_run "$@" ;;
                *) error "Unknown skill subcommand: $sub"; exit 1 ;;
            esac
            ;;
        publish)
            # udo publish [--input dir] [--output dir] [--watch] [--force]
            # udo publish index
            local input_dir=""
            local output_dir=""
            local watch_mode=false
            local force_mode=false

            if [ "$1" = "index" ]; then
                shift
                # Regenerate index only
                info "Regenerating index..."
                node "$HOME/Code/uConnect/tools/localhost-library/server.ts" --generate-index 2>/dev/null || \
                    warn "Index regeneration not available (run 'udo publish' first)"
                return
            fi

            while [ $# -gt 0 ]; do
                case "$1" in
                    --input) input_dir="$2"; shift 2 ;;
                    --output) output_dir="$2"; shift 2 ;;
                    --watch) watch_mode=true; shift ;;
                    --force) force_mode=true; shift ;;
                    *) shift ;;
                esac
            done

            info "Publishing static site..."
            local cmd="node -e "
            cmd+='"const { handlePublish, handlePublishWatch } = require('"'./packages/udos/commands/publish.ts'"'); "
            if [ "$watch_mode" = true ]; then
                cmd+="handlePublishWatch({ input: '${input_dir:-}', output: '${output_dir:-}' });"
            else
                cmd+="handlePublish({ input: '${input_dir:-}', output: '${output_dir:-}', force: ${force_mode} }).then(r => process.exit(r.success ? 0 : 1));"
            fi
            cmd+='"'
            eval "$cmd" 2>/dev/null || {
                warn "Publish command not available via Node"
                echo "  Try: cd ~/Code/uConnect && npx tsx packages/udos/commands/publish.ts"
            }
            ;;
        serve)
            # udo serve — Start localhost library server on port 8080
            info "Starting localhost library server..."
            if [ -f "$HOME/Code/uConnect/tools/localhost-library/server.ts" ]; then
                cd "$HOME/Code/uConnect"
                npx tsx tools/localhost-library/server.ts 2>/dev/null || \
                    node tools/localhost-library/server.ts 2>/dev/null || {
                    warn "Failed to start server"
                    echo "  Try: cd ~/Code/uConnect && npx tsx tools/localhost-library/server.ts"
                }
            else
                warn "Server script not found"
            fi
            ;;
        oracle)
            # udo oracle ask <query> [--domain <domain>] [--verbose]
            # udo oracle list
            # udo oracle status
            [ $# -lt 1 ] && { error "Usage: udo oracle <ask|list|status>"; exit 1; }
            local sub="$1"; shift
            case "$sub" in
                ask)
                    local domain=""
                    local verbose=false
                    local query=""

                    while [ $# -gt 0 ]; do
                        case "$1" in
                            --domain) domain="$2"; shift 2 ;;
                            --verbose) verbose=true; shift ;;
                            *) query="$*"; break ;;
                        esac
                    done

                    if [ -z "$query" ]; then
                        error "Usage: udo oracle ask <query> [--domain knowledge|creation|insight] [--verbose]"
                        exit 1
                    fi

                    info "Consulting the oracles..."
                    cd "$HOME/Code/uConnect"
                    npx tsx -e "
                        const { handleOracleAsk } = require('./packages/udos/commands/oracle.ts');
                        handleOracleAsk({ prompt: '$query', domain: '${domain}', verbose: ${verbose} }).then(() => process.exit(0));
                    " 2>/dev/null || {
                        warn "Oracle command not available via Node"
                        echo "  Try: cd ~/Code/uConnect && npx tsx -e '...'"
                    }
                    ;;
                list)
                    cd "$HOME/Code/uConnect"
                    npx tsx -e "
                        const { handleOracleList } = require('./packages/udos/commands/oracle.ts');
                        handleOracleList();
                    " 2>/dev/null || {
                        warn "Oracle list not available"
                        echo "  Available oracles: knowledge, creation, insight"
                    }
                    ;;
                status)
                    cd "$HOME/Code/uConnect"
                    npx tsx -e "
                        const { handleOracleStatus } = require('./packages/udos/commands/oracle.ts');
                        handleOracleStatus();
                    " 2>/dev/null || {
                        warn "Oracle status not available"
                        echo "  Status: fallback mode (no LLM provider configured)"
                    }
                    ;;
                *)
                    error "Unknown oracle subcommand: $sub"
                    echo "  Usage: udo oracle <ask|list|status>"
                    exit 1
                    ;;
            esac
            ;;
        *)

            error "Unknown command: $cmd"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
