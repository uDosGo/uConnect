    "axios": "^1.4.0",
    "glob": "^10.3.3",
    "lodash": "^4.17.21",
    "yaml": "^2.3.1",
    "@actions/core": "^1.10.0",
    "@actions/github": "^5.1.1"
  },
  "devDependencies": {
    "typescript": "^5.0.4",
    "ts-node": "^10.9.1",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/fs-extra": "^11.0.1",
