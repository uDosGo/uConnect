# Local machine pointer (written by scripts/bootstrap-family-python.sh)
.udos-connect-python
.udos-family-python

# macOS / Windows noise
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Editor / IDE
*.swp
*.swo
.idea/
.vscode/

# Local workspace overrides (keep *.code-workspace committed)
*.local.code-workspace
*.code-workspace.local

# Local override filename patterns (machine-specific)
*.local.*
*-local.*

# Scratch (family convention)
.local/
# A1 contributor-only scratch under dev/ — see dev/.gitignore (`local/`)
.compost/*
!.compost/README.md

# Cursor local cache (large)
.cursor/cache/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Logs
*.log

# Rust / Cargo
**/target/

# Rust profiling artifacts
default.profraw
*.profraw

# Ad-hoc test run artefacts (optional; narrow if these extensions are used for real sources)
*.test
*.fail

# Node / JS
node_modules/
dist/
package-lock.json
pnpm-lock.yaml
yarn.lock

# Rust / Cargo lock (managed by workspace)
Cargo.lock

# Version file (redundant with package.json)
version

# Optional local vendor clones (nested upstream repos; not part of monorepo history)
vendor/

# Aggressive cleanup exclusions - NEVER COMMIT THESE
.archive/
.compost/
.backup/
*.tmp
*.bak
core.*
.cache/
.parcel-cache/
.next/
.nuxt/
.output/
coverage/
.nyc_output/
jest-coverage/
.env

# Legacy (from HEAD version)
.state/
Sandbox/
_deprecated/
Vendor/.legacy/

# Additional Python
*.egg-info/

# Additional local data
.local/

# Added by cargo
/target*.ttf
