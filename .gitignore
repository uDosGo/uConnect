.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Editor / IDE
*.swp
*.swo
.idea/
.vscode/

# Local workspace overrides (keep *.code-workspace committed)
*.local.code-workspace
*.code-workspace.local

# Local override filename patterns (machine-specific)
*.local.*
*-local.*

# Scratch (family convention)
.local/
# A1 contributor-only scratch under dev/ — see dev/.gitignore (`local/`)
.compost/*
!.compost/README.md

# Cursor local cache (large)
.cursor/cache/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Logs
*.log

# Rust / Cargo (workspace: core-rs/)
core-rs/target/

# Ad-hoc test run artefacts (optional; narrow if these extensions are used for real sources)
*.test
*.fail

# A1 TypeScript build artefacts (core, tools, modules)
node_modules/
core/dist/
tools/sonic-express/dist/
tools/usxd-express/dist/
