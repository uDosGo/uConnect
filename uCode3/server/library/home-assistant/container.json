{
  "$schema": "../container.schema.json",
  "container": {
    "id": "home-assistant",
    "name": "Home Assistant",
    "description": "Open-source home automation platform with local control and privacy focus",
    "type": "git",
    "source": "https://github.com/home-assistant/core",
    "ref": "master",
    "cloned_at": null,
    "last_update": null,
    "commit": null,
    "version": null
  },
  "policy": {
    "read_only": true,
    "auto_update": false,
    "update_channel": "uhome_only",
    "verify_signatures": false,
    "thin_kiosk_only": false,
    "runtime_owner": "uhome",
    "execution_model": "container-library-v1"
  },
  "service": {
    "port": 8765,
    "health_check_url": "http://localhost:8765/health",
    "browser_route": "/ui/home-assistant"
  },
  "launch_config": {
    "command": [
      "python3",
      "-m",
      "uhome_server.services.home_assistant"
    ],
    "cwd": "."
  },
  "integration": {
    "wrapper_path": "src/uhome_server/services/home_assistant/",
    "handler_path": "src/uhome_server/routes/home_assistant.py",
    "install_script": null
  },
  "metadata": {
    "license": "Apache-2.0",
    "homepage": "https://www.home-assistant.io/",
    "documentation": "https://developers.home-assistant.io/",
    "maintainer": "Home Assistant / uHOME Server",
    "category": "home_automation",
    "callable_from": ["uhome", "thin-kiosk"]
  },
  "repo_path": "library/containers/home-assistant"
}
