{
  "name": "Hivemind Sonic-Express Handler",
  "version": "1.0.0",
  "description": "High-performance MCP handler for Hivemind system",
  "port": 30001,
  "dsc2": {
    "endpoint": "http://localhost:30000/mcp",
    "use_real_server": false,
    "timeout_ms": 30000,
    "max_retries": 3,
    "fallback_to_mock": true
  },
  "cache": {
    "enabled": true,
    "ttl_seconds": 3600,
    "max_size_mb": 32,
    "strategy": "lru"
  },
  "quality": {
    "min_score": 0.7,
    "fallback_enabled": true,
    "evaluation_model": "gemini-flash"
  },
  "rate_limiting": {
    "enabled": true,
    "max_requests_per_minute": 60,
    "burst_limit": 10
  },
  "logging": {
    "level": "info",
    "file": "logs/sonic-express.log",
    "max_size": "10m",
    "max_files": 5
  },
  "security": {
    "require_auth": false,
    "api_key": "",
    "https": {
      "enabled": false,
      "cert": "",
      "key": ""
    }
  },
  "metrics": {
    "enabled": true,
    "port": 9090,
    "prometheus": true
  },
  "health_check": {
    "interval_ms": 60000,
    "threshold": 0.95
  }
}