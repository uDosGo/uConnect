{
  "name": "@udos/localhost-library",
  "version": "1.0.0",
  "description": "uDosConnect Localhost Library - Web Server & User Portal",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
