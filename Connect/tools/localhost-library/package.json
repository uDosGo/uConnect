    "test:build": "tsc && node dist/test-integration.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cookie-parser": "^1.4.6",
    "chalk": "^5.3.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.6",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cookie-parser": "^1.4.3",
    "@types/node": "^20.11.5",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "typescript": "^5.3.3",
    "tsc-watch": "^6.0.4",
    "ts-node": "^10.9.2",
    "@types/uuid": "^9.0.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
