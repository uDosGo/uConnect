{
  "name": "@vibecli/tui-go-react",
  "version": "1.0.0",
  "description": "VibeCLI TUI-Go-React Module - Unified Terminal and Web Interfaces",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && esbuild dist/index.js --minify --outfile=dist/index.min.js",
    "build:tui": "cd tui && go build -o ../dist/tui-main",
    "build:react": "cd react && vite build",
    "dev:react": "cd react && vite dev",
    "test": "jest",
    "test:tui": "cd tui && go test ./...",
    "lint": "eslint src/**/*.ts && cd tui && golangci-lint run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vibecli/core": "1.0.0",
    "@vibecli/grid-gui-surfaces": "1.0.0",
    "@vibecli/shared-utils": "1.0.0",
    "@vibecli/types": "1.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "eslint": "^8.0.0",
    "esbuild": "^0.19.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "go": ">=1.20.0"
  },
  "keywords": ["vibecli", "tui", "react", "cli", "modular"],
  "author": "VibeCLI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vibecli/vibecli.git"
  }
}